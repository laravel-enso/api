            "email": "aocneanu@gmail.com",
            "homepage": "https://laravel-enso.com",
            "role": "Developer"
        },
        {
            "name": "Vlad Chiovianu",
            "email": "vlad.chiovianu@earthlink.ro",
            "homepage": "https://laravel-enso.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-enso/core": "^12.0",
        "laravel-enso/enums": "^3.0",
        "laravel-enso/helpers": "^4.0",
        "laravel-enso/localisation": "^5.0",
        "laravel-enso/permissions": "^5.0",
        "laravel-enso/rememberable": "^4.0",
        "laravel-enso/tables": "^5.0",
        "laravel-enso/upgrade": "^2.0",
        "laravel-enso/users": "^2.0",
        "laravel/framework": "^12.0|^13.0"
